{
  "name": "AgentSmith",
  "image": "mcr.microsoft.com/devcontainers/python:3.12",
  "features": {
    "ghcr.io/devcontainers/features/node:1": { "version": "22" },
    "ghcr.io/devcontainers-extra/features/uv:1": {}
  },
  "forwardPorts": [18900, 3100],
  "containerEnv": {
    "AGENTSMITH_DB_URL": "mysql+pymysql://root:root@host.docker.internal:3306/agent_smith",
    "AGENTSMITH_STATIC_DIR": "${containerWorkspaceFolder}/agentsmith_web/dist"
  },
  "mounts": [
    "source=/mnt/e/Documents/github/cjml-cheap-weixiu/logs,target=/data/logs,type=bind"
  ],
  "postCreateCommand": "uv sync && cd agentsmith_web && npm install",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.debugpy"
      ],
      "settings": {
        "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
        "python.testing.pytestEnabled": true,
        "python.testing.pytestArgs": ["tests/"]
      }
    }
  }
}
