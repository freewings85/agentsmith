{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Server",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "agentsmith_server.app:app",
        "--host", "0.0.0.0",
        "--port", "8120",
        "--reload"
      ],
      "env": {
        "AGENTSMITH_DB_URL": "mysql+pymysql://root:root@host.docker.internal:3306/agent_smith",
        "AGENTSMITH_STATIC_DIR": "${workspaceFolder}/agentsmith_web/dist",
        "NO_PROXY": "localhost,127.*,10.*,192.168.*"
      },
      "preLaunchTask": "build-frontend",
      "jinja": true,
      "justMyCode": false
    },
    {
      "name": "Collector",
      "type": "debugpy",
      "request": "launch",
      "module": "agentsmith_collector",
      "args": [
        "--logs-dir", "/data/logs",
        "--server-url", "http://127.0.0.1:8120",
        "--poll-interval", "5"
      ],
      "env": {
        "NO_PROXY": "localhost,127.*,10.*,192.168.*"
      },
      "jinja": true,
      "justMyCode": false
    }
  ]
}
